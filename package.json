{
  "name": "promptops-gui",
  "version": "1.0.0",
  "description": "Deterministic PromptOps engine + GUI operator tooling with evidence-first sprint workflows",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite --config src/s17/vite.config.ts",
    "test:s18": "node --test --experimental-transform-types tests/s18/*.test.ts",
    "verify:s18": "bash scripts/verify_s18.sh",
    "preflight": "bash scripts/preflight.sh",
    "build": "tsc --noEmit && npm run -s build:bundle-analysis",
    "build:bundle-analysis": "vite build --config vite.config.ts",
    "test": "npm run -s test:all",
    "test:unit": "node --test --experimental-transform-types engine/command_executor.test.ts engine/preflight_s06.test.ts engine/evaluator.test.ts engine/events/schema.test.ts policy/index.test.ts",
    "test:integration": "node --test --experimental-transform-types engine/integration.test.ts",
    "test:all": "npm run -s test:unit && npm run -s test:integration",
    "test:evaluator": "node --test --experimental-transform-types engine/evaluator.test.ts",
    "test:evaluator:junit": "mkdir -p coverage && node --test --experimental-transform-types --test-reporter=junit --test-reporter-destination=coverage/junit.xml engine/evaluator.test.ts",
    "coverage:evaluator": "rm -rf coverage && mkdir -p coverage && c8 --reporter=lcov --reporter=text-summary --report-dir=coverage node --test --experimental-transform-types engine/evaluator.test.ts",
    "simulate:migration": "bash scripts/migration-sim.sh",
    "lint": "bash scripts/verify.sh lint",
    "verify": "bash scripts/verify.sh all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doogie201/promptops-gui.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Doogie201/promptops-gui/issues"
  },
  "homepage": "https://github.com/Doogie201/promptops-gui#readme",
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@types/node": "^25.3.2",
    "c8": "^11.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
